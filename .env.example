# --- Bot Mode Configuration ---
PAPER_TRADING=True
DB_PATH=data/trading_bot.db
WEB_PORT=9090
WEB_HOST=127.0.0.1

# --- Binance API Configuration ---
# If PAPER_TRADING=True, these should be Binance Testnet API keys
# If PAPER_TRADING=False, these should be live Binance API keys
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_here
BINANCE_USE_TESTNET=False

# --- Telegram Notifications (Optional) ---
TELEGRAM_ENABLED=False
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Risk Management Configuration ---
RISK_PER_TRADE_PCT=1.0
MAX_CONCURRENT_TRADES=3
DAILY_DRAWDOWN_LIMIT_PCT=5.0
DEFAULT_LEVERAGE=1

# --- Strategy Configuration ---
# Options: 'ema' (EMA Crossover), 'cipher' (Gated Cipher B), or 'both' (runs both concurrently)
STRATEGY_TYPE=ema
TIMEFRAME=1h
SCAN_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,ADA/USDT,DOT/USDT,DOGE/USDT,XRP/USDT,LINK/USDT
EMA_FAST_PERIOD=20
EMA_SLOW_PERIOD=50
RSI_PERIOD=14
RSI_MIN_MOMENTUM=50
RSI_MAX_MOMENTUM=65
ATR_PERIOD=14
ATR_MULTIPLIER_SL=1.5
ATR_MULTIPLIER_TP=3.0
